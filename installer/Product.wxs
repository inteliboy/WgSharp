<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX Toolset v3.14 source for the WgSharp MSI installer.

  Built directly with candle.exe/light.exe from build.cmd — no MSBuild, no
  Visual Studio WiX project, consistent with how the rest of WgSharp is built.

  Inputs passed in from build.cmd via -d preprocessor variables:
    ProductVersion  e.g. "1.26.0629"; the leading 3 fields of the SAME date
                    encoding the exe's own AssemblyVersion gets (which is
                    4 fields, "1.26.0629.0"; see build.cmd). Windows
                    Installer's Version format is strictly 3-part
                    (major.minor.build) and rejects a 4th field outright, so
                    this can't be byte-for-byte identical to the exe's
                    version string; it's the closest match Windows
                    Installer allows.
    SourceDir       full path to the built bin\amd64 folder (contains WgSharp.exe)
    RepoDir         full path to the repo root (contains LICENSE, README.md, WgSharp.ico)

  What this installs:
    - WgSharp.exe to a FIXED location, Program Files\WgSharp (no "choose a
      folder" dialog; see the UI comment further down for why)
    - LICENSE and README.md alongside it
    - A Start Menu shortcut (with an Uninstall entry alongside it)
    - Standard Add/Remove Programs registration
    - Closes a running WgSharp automatically before touching its files —
      BOTH the GUI (util:CloseApplication, with a guaranteed TerminateProcess
      fallback) and the background service (ServiceControl, since it's the
      same exe but has no window) — see the comment below the MajorUpgrade
      element for the full explanation.

  What this deliberately does NOT do:
    - Install/start the background service, or touch the Windows Firewall, or
      enable login autostart; those are WgSharp's OWN first-run behavior
      (see src/core/InstallLocation.cs): when WgSharp detects it's running
      from this exact installed path, it enables autostart + the service by
      default and disallows turning on Portable mode, entirely on its own at
      first run. The installer's job is just to put the exe on disk;
      everything else happens the first time the app itself starts.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*"
           Name="WgSharp"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="inteliboy"
           UpgradeCode="9E3F2B7E-6B5B-4C8C-9B7F-1B6E2F2A4A11">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Platform="x64"
             Description="WgSharp - a from-scratch WireGuard client for Windows"
             Manufacturer="inteliboy" />

    <!-- Same-product upgrades: installing a newer dated build replaces the
         older one in place rather than producing a side-by-side mess.

         AllowSameVersionUpgrades="yes" is NOT optional polish — without it,
         this was the actual, confirmed cause of "WgSharp.exe doesn't get
         replaced": Product Id="*" generates a brand-new ProductCode on
         EVERY build, but our date-based version (1.YY.MMDD; see build.cmd)
         only has DAY granularity. Rebuild and reinstall twice on the same
         day (an everyday dev/test scenario, and exactly what was happening
         here) and the new MSI has a DIFFERENT ProductCode but the IDENTICAL
         ProductVersion as the one already installed. Per Windows
         Installer's own documented behavior, with this attribute left at
         its default ("no"), that combination is NOT treated as a major
         upgrade at all; it's treated as two unrelated products. The
         already-installed one (and its files, including WgSharp.exe) is
         never touched, no matter how cleanly the running processes were
         closed first; a same-version "upgrade" silently installs alongside
         it instead of replacing it. AllowSameVersionUpgrades="yes" makes an
         equal-version product also count as "older, remove it" for this
         UpgradeCode, which is exactly the behavior every rebuild here
         needs. WiX's ICE61 validation specifically flags this exact
         configuration as unusual ("this product should remove only OLDER
         versions of itself"); it's correctly describing what we're
         deliberately asking for, not catching a real mistake, so it's
         suppressed via -sice:ICE61 in build.cmd's light.exe invocation. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of WgSharp is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Closing a running WgSharp before files are touched needs TWO
         mechanisms, since one WgSharp.exe plays two roles:

         (1) The SERVICE (name "WgSharpSvc", the same WgSharp.exe run with a
             "service" argument as LocalSystem, no window): stopped via
             <ServiceControl> below, attached to the MainExecutable
             component, a core Windows Installer feature (the standard
             StopServices action). The engine itself calls the Service
             Control Manager's ControlService(STOP) and, with Wait="yes",
             synchronously waits for it to actually exit, before files are
             written.

         (2) The GUI/tray process: util:CloseApplication, below. Earlier
             revisions of this file used CloseMessage alone, which sends a
             bare WM_CLOSE — and a WM_CLOSE arriving from another process is
             INDISTINGUISHABLE, at the WinForms level, from the user
             clicking the title-bar X (both default to
             CloseReason.UserClosing), so it got swallowed by MainForm's
             intentional "X minimizes to tray, doesn't exit" behavior
             instead of actually closing the app. The fix is
             EndSessionMessage="yes": it sends WM_QUERYENDSESSION/
             WM_ENDSESSION instead, which .NET WinForms specifically maps to
             CloseReason.WindowsShutDown — a reason MainForm.OnFormClosing
             already treats as "really exit" (it only special-cases
             UserClosing), with no custom code required on our side.
             ElevatedCloseMessage="yes" is required because WgSharp's
             manifest forces it to run elevated, so a plain close request
             wouldn't reach it.

             TerminateProcess="1" with a short Timeout is the actual
             guarantee, not just a nicety: if the graceful attempts above
             don't succeed for any reason within the timeout, Setup forcibly
             terminates the process outright before files are written. This
             closes off every remaining failure mode (a hung message loop,
             an unexpected exception during the synchronous in-process
             tunnel teardown in OnFormClosing, anything) — the exe is
             guaranteed unlocked by file-write time regardless of how
             gracefully (or not) WgSharp itself responds. -->
    <util:CloseApplication Id="CloseWgSharpGui"
                           Target="WgSharp.exe"
                           CloseMessage="yes"
                           EndSessionMessage="yes"
                           ElevatedCloseMessage="yes"
                           TerminateProcess="1"
                           Timeout="5"
                           RebootPrompt="no"
                           Description="WgSharp is running and needs to close before Setup can continue. Setup will close it automatically." />
    <Icon Id="WgSharpIcon" SourceFile="$(var.RepoDir)\WgSharp.ico" />
    <Property Id="ARPPRODUCTICON" Value="WgSharpIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/inteliboy/WgSharp" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />

    <!-- x64-only install location, matching WgSharp's amd64-only build. -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="WgSharp" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="WgSharp" />
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="*" Win64="yes">
        <File Id="WgSharpExe" Source="$(var.SourceDir)\WgSharp.exe" KeyPath="yes" />
        <!-- Deterministically stops the background service (service name
             "WgSharpSvc", see src/core/ServiceInstaller.cs) before files
             are replaced, on BOTH install and uninstall. This is a core MSI
             feature (the standard StopServices action), not a custom action
             or Restart Manager heuristic: Windows Installer itself calls
             ControlService(SERVICE_CONTROL_STOP) and, with Wait="yes",
             synchronously waits for it to actually stop, sequenced (by the
             engine's own standard action order) after InstallValidate but
             reliably before InstallFiles. That ordering matters: the
             service runs the exact same WgSharp.exe as the GUI but has no
             window and never registers for preshutdown notifications, so
             Restart Manager's own "close and restart" mechanism (which the
             native Files in Use dialog offers) can detect and list it but
             can't reliably stop it, exactly the gap that left WgSharp.exe
             locked and un-replaced even after clicking through that prompt.
             ServiceControl doesn't have that limitation: it talks to the
             Service Control Manager directly and is unconditional, so the
             exe is genuinely unlocked by the time it's written regardless of
             what Restart Manager did or didn't manage on its own.
             Remove="uninstall" also deletes the service registration when
             WgSharp itself is uninstalled, so nothing's left orphaned. -->
        <ServiceControl Id="StopWgSharpService"
                        Name="WgSharpSvc"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
        <!-- wintun.dll and wireguard.dll are NOT installed by this MSI at
             all; they're downloaded by WgSharp itself at first run/connect
             (see WintunDownloader.cs / WireGuardNtDownloader.cs), straight
             into the exe's own directory (AppDomain.CurrentDomain.
             BaseDirectory, which for an installed copy is exactly
             INSTALLFOLDER). Since Windows Installer never tracked them as
             belonging to any component, a normal uninstall has no idea they
             exist and would leave them behind, and would likely leave
             INSTALLFOLDER itself behind too, since MSI only auto-removes a
             directory once everything in it (including untracked leftovers)
             is gone. RemoveFile here explicitly deletes them on uninstall
             even though this component never installed them; the defensive
             RemoveFolder right after makes sure INSTALLFOLDER itself goes
             away too once those last two files are cleared out. -->
        <RemoveFile Id="RemoveWintunDll" Name="wintun.dll" On="uninstall" />
        <RemoveFile Id="RemoveWireGuardDll" Name="wireguard.dll" On="uninstall" />
        <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      </Component>
      <Component Id="LicenseFile" Guid="*" Win64="yes">
        <File Id="LicenseTxt" Source="$(var.RepoDir)\LICENSE" Name="LICENSE.txt" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeFile" Guid="*" Win64="yes">
        <File Id="ReadmeMd" Source="$(var.RepoDir)\README.md" Name="README.md" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcuts" Guid="*" Win64="yes">
        <RemoveFolder Id="CleanUpShortcutFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        <!-- The shortcut lives in ITS OWN component, keyed on an HKCU
             registry value rather than the exe file — not just tidiness:
             putting it on the per-machine exe File's KeyPath instead (as an
             earlier version of this file did) trips two ICE validations:
             ICE43 (non-advertised shortcuts need an HKCU KeyPath, not a
             file) and ICE57 (a single component can't mix per-machine data,
             the Program-Files file, with per-user data, an HKCU value, under
             one KeyPath). Since the shortcut isn't nested inside its target
             File element here, Target must be set explicitly. -->
        <Shortcut Id="StartMenuShortcut"
                   Directory="ApplicationProgramsFolder"
                   Name="WgSharp"
                   Target="[INSTALLFOLDER]WgSharp.exe"
                   WorkingDirectory="INSTALLFOLDER"
                   Icon="WgSharpIcon"
                   IconIndex="0" />
        <RegistryValue Root="HKCU" Key="Software\WgSharp" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="WgSharp" Level="1" AllowAdvertise="no">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="LicenseFile" />
      <ComponentRef Id="ReadmeFile" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <!-- Stock minimal UI (Welcome -> License -> Install -> Finish) — no
         "choose install folder" dialog, so the location is fixed at
         Program Files\WgSharp and can't be changed at install time. This is
         intentional: WgSharp detects when it's running from that exact path
         (see InstallLocation.cs) and changes its defaults accordingly
         (auto-enables autostart + the background service, and disallows
         Portable mode) — a movable install location would break that
         detection. Anyone who wants a relocatable/portable copy should use
         the plain exe from the zip distribution instead of this installer. -->
    <UIRef Id="WixUI_Minimal" />
    <UIRef Id="WixUI_ErrorProgressText" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.RepoDir)\installer\License.rtf" />

    <!-- "Launch WgSharp when Setup exits" checkbox on the Finish dialog.
         WixShellExec (and the WixCA binary it runs from) come from
         WixUtilExtension, referenced alongside WixUIExtension in build.cmd. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch WgSharp when Setup exits" />
    <Property Id="WixShellExecTarget" Value="[#WgSharpExe]" />
    <CustomAction Id="LaunchApplication" BinaryKey="WixCA" DllEntry="WixShellExec" Impersonate="yes" />
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication">
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed
      </Publish>
    </UI>
  </Product>
</Wix>
